<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<system.webServer>
		<!--
			Allows non-2xx responses from the ColdFusion server to be rendered by IIS.
			Without this, IIS will intercept the error responses and render its own error.
		-->
		<httpErrors existingResponse="PassThrough" />
	</system.webServer>
	<!--
		Sets aggressive caching headers on Parcel-built static assets. Since Parcel
		generates content-hashed filenames, a long max-age is safe — the hash changes
		whenever the file content changes.
	-->
	<location path="static/main">
		<system.webServer>
			<staticContent>
				<clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
			</staticContent>
			<httpProtocol>
				<customHeaders>
					<add name="Cache-Control" value="public, max-age=31536000, immutable" />
				</customHeaders>
			</httpProtocol>
		</system.webServer>
	</location>
</configuration>
